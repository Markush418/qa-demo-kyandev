{
  "name": "document-qa-demo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n server,client -c blue,green \"bun run dev:server\" \"bun run dev:client\"",
    "dev:server": "bun run --watch src/server/index.ts",
    "dev:client": "vite",
    "build:client": "vite build",
    "build": "bun run build:client",
    "start": "NODE_ENV=production bun run db:migrate && NODE_ENV=production bun run src/server/index.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun run src/server/db/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "typecheck": "bun run typecheck:server && bun run typecheck:client",
    "typecheck:server": "tsc --noEmit -p tsconfig.server.json",
    "typecheck:client": "tsc --noEmit -p tsconfig.client.json"
  },
  "dependencies": {
    "drizzle-orm": "^0.36.4",
    "hono": "^4.6.14",
    "mammoth": "^1.8.0",
    "nanoid": "^5.0.9",
    "openai": "^4.77.0",
    "pdf-parse": "^1.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/pdf-parse": "^1.1.4",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "bun-types": "^1.3.14",
    "concurrently": "^9.1.0",
    "drizzle-kit": "^0.28.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^6.0.3"
  }
}
